# Local job-agent-v2 configuration.
# Copy this file to .env.local and fill in the values.
# .env.local is ignored by Git.

JOBAGENT_DB_PATH=data/local-test/jobagent.sqlite3
JOBAGENT_ARTIFACT_DIR=data/local-test/artifacts
JOBAGENT_OWNER_ID=local

JOBAGENT_API_HOST=127.0.0.1
JOBAGENT_API_PORT=8765
JOBAGENT_FRONTEND_HOST=127.0.0.1
JOBAGENT_FRONTEND_PORT=5173

JOBAGENT_LLM_ENABLED=true
JOBAGENT_LLM_API_KEY=
JOBAGENT_LLM_MODEL=gpt-5.4-mini
JOBAGENT_LLM_TIMEOUT_SECONDS=30
JOBAGENT_LLM_RETRY_COUNT=1

JOBAGENT_LOG_LEVEL=INFO

JOBAGENT_Q1_POLL_SECONDS=5
JOBAGENT_Q2_POLL_SECONDS=5
JOBAGENT_REGENERATION_POLL_SECONDS=5
JOBAGENT_HEARTBEAT_SECONDS=10
JOBAGENT_STALE_PROCESSING_SECONDS=900
JOBAGENT_MAX_RETRY_ATTEMPTS=3
JOBAGENT_PROMOTION_INTERVAL_SECONDS=60
JOBAGENT_Q2_CAPACITY=8
JOBAGENT_Q2_WORKER_CONCURRENCY=1
JOBAGENT_AUTO_PROMOTE_THRESHOLD=82
JOBAGENT_MANUAL_REVIEW_THRESHOLD=70
JOBAGENT_AUTO_PACKET_BUDGET=10
JOBAGENT_PROMOTION_SCHEDULER_ENABLED=true
JOBAGENT_LATEX_EXECUTABLE=pdflatex
